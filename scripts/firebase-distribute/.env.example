# Copy this file to .env (same folder) and fill in your values.
# .env is gitignored — never commit it.

# From Firebase console: Project Settings → Your apps → App ID
# Looks like: 1:123456789:android:abcdef123456
FIREBASE_APP_ID=

# Comma-separated list of tester emails
FIREBASE_TESTERS=you@example.com

# Optional: default release notes (overridden by passing a CLI arg or git commit message)
FIREBASE_RELEASE_NOTES=
