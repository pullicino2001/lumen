# Copy this file to .env (same folder) and fill in your values.
# .env is gitignored — never commit it.

# GitHub personal access token (fine-grained, Contents: read+write, single repo)
GITHUB_TOKEN=

# owner/repo — e.g. pullicino2001/lumen
GITHUB_REPO=

# Discord incoming webhook URL
DISCORD_WEBHOOK=

# Human-readable app name used in Discord message and APK filename
APP_NAME=
